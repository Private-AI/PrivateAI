{
  "name": "privateai-presentation",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "postbuild": "node -e \"const {cpSync}=require('fs'),p=require('path');['videos','audio'].forEach(d=>{try{cpSync(p.join('public',d),p.join('..','frontend','public',d),{recursive:true,force:true});console.log('copied',d)}catch(e){console.warn('skip',d,e.message)}})\"",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.4"
  }
}
