# Copy this file to .env.prod on the server and fill in your values.
# NEVER commit .env.prod to git.

# ── Your DuckDNS subdomain ─────────────────────────────────────────────
DOMAIN_HOST=myapp.duckdns.org
DOMAIN_URL=https://myapp.duckdns.org

# ── Caddy (automatic SSL) ──────────────────────────────────────────────
CADDY_EMAIL=you@example.com

# ── CORS (allow the main app + Open WebUI port to call the backend) ────
ALLOWED_ORIGINS=https://myapp.duckdns.org,https://myapp.duckdns.org:8443

# ── Open WebUI public URL (what the browser uses for the iframe) ───────
OPEN_WEBUI_PUBLIC_URL=https://myapp.duckdns.org:8443

# ── Internals (no need to change) ─────────────────────────────────────
PYTHONPATH=/app/backend
PYTHONUNBUFFERED=1
OPEN_WEBUI_VENV=/opt/open-webui-env
OPEN_WEBUI_DATA_DIR=/app/open-webui-data
OPEN_WEBUI_PORT=8080
