# PrivateAI Hosted Demo — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.hosted.example .env

# ── Required ──────────────────────────────────────────────────────────

# Secret key for JWT token signing (generate a strong random string)
PRIVATEAI_SECRET_KEY=change-me-to-a-random-64-char-string

# Host port to expose Nginx on (default: 80)
HOST_PORT=80

# ── Optional ──────────────────────────────────────────────────────────

# Additional CORS origins (comma-separated)
# PRIVATEAI_CORS_ORIGINS=https://your-domain.com

# Open WebUI secret key (for cookie signing)
OPEN_WEBUI_SECRET_KEY=change-me-too

# Ollama base URLs (semicolon-separated, for Open WebUI default config)
# OLLAMA_BASE_URLS=http://your-vm-ip:11434
